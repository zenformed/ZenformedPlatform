# --- Supabase (browser auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service role for admin docs CRUD and migration scripts.
# Required when DOCS_CONTENT_SOURCE=database.
SUPABASE_SERVICE_ROLE_KEY=

# Documentation content source: markdown (local default) or database (production).
DOCS_CONTENT_SOURCE=markdown

# Docs image uploads: filesystem (local default) or supabase (required on Vercel).
# Production uses Supabase Storage bucket platform-docs-images (see supabase/migrations/20260628130000_create_platform_docs_images_bucket.sql).
# Requires NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY on Vercel.
DOCS_IMAGES_STORAGE=

# --- SaaS gate (required) ---
NEXT_PUBLIC_SAAS_MODE=true

# Public platform app URL (password recovery emails, auth redirects).
# Local: http://localhost:3030
# Production: https://core.zenformed.com
PLATFORM_PUBLIC_APP_URL=http://localhost:3030

# Supabase dashboard (required for direct /register email verification):
# - Authentication → Providers → Email → Confirm email: enabled
# - Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3030/login
#   https://core.zenformed.com/login
#   (also keep /reset-password URLs for password recovery)

# BuildCore public URL for local cross-app login handoff (Platform → BuildCore).
# When unset in dev, defaults to http://localhost:3020 while Platform runs on localhost.
# BUILDCORE_PUBLIC_APP_URL=http://localhost:3020

# Optional client-visible override for auth redirects in browser.
# NEXT_PUBLIC_PLATFORM_APP_URL=http://localhost:3030

# --- ZenformedCore API (server-side BFF relay) ---
ZENFORMED_CORE_API_URL=http://localhost:4000
